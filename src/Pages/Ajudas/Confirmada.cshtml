@page "/Ajudas/Confirmada"
@model ConexaoSolidaria.Pages.Ajudas.ConfirmadaModel
@{
    ViewData["Title"] = "Ajuda Confirmada";
    var o = Model.Oferta;
    var s = Model.Solicitacao;
    var pct = 0;

    string itensLabel = o?.Mensagem ?? "—";
    string modalidadeLabel = o?.Modalidade switch
    {
        "doacao"       => "Doacao de Itens",
        "voluntariado" => "Voluntariado Presencial",
        "transporte"   => "Transporte",
        _              => o?.Modalidade ?? "—"
    };
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-page="/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-page="/Solicitacoes/Index">Solicitacoes</a></li>
        @if (s != null)
        {
            <li class="breadcrumb-item">
                <a asp-page="/Solicitacoes/Detalhes" asp-route-id="@s.Id">Detalhes</a>
            </li>
        }
        <li class="breadcrumb-item active" aria-current="page">Ajuda Confirmada</li>
    </ol>
</nav>

@if (o == null || s == null)
{
    <div class="alert alert-danger">Oferta nao encontrada.</div>
}
else
{
    <div class="cs-alert-success mb-4">
        <div class="cs-alert-icon">&#10003;</div>
        <div>
            <div class="fw-bold fs-5 text-success">Ajuda confirmada com sucesso!</div>
            <div class="text-success-muted">
                Sua oferta foi registrada. Entre em contato com o solicitante pelo chat.
            </div>
            <small class="text-muted">Codigo da oferta: #OF-@o.Id.ToString("D4")</small>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card cs-card mb-4">
                <div class="card-header cs-card-header-primary text-white fw-semibold">
                    Resumo da sua oferta de ajuda
                    <span class="badge cs-badge-ok float-end">Confirmada</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-borderless mb-0 cs-table-resumo">
                        <tbody>
                            <tr>
                                <th class="text-muted ps-3" style="width:38%">Modalidade</th>
                                <td class="fw-bold">@modalidadeLabel</td>
                            </tr>
                            <tr>
                                <th class="text-muted ps-3">Observacoes</th>
                                <td class="fw-bold">
                                    @(string.IsNullOrWhiteSpace(o.Mensagem)
                                        ? "A combinar via chat"
                                        : o.Mensagem)
                                </td>
                            </tr>
                            <tr>
                                <th class="text-muted ps-3">Solicitacao</th>
                                <td class="fw-bold">@s.Titulo — @s.Cidade / @s.Estado</td>
                            </tr>
                            <tr>
                                <th class="text-muted ps-3">Status</th>
                                <td class="fw-bold text-success">Confirmada — aguardando entrega</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card cs-card bg-light border-0 mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Proximos passos</h5>
                    <ol class="cs-next-steps ps-0 mb-0">
                        <li>
                            <div class="cs-step-num">1</div>
                            Use o chat da plataforma para combinar os detalhes da entrega.
                        </li>
                        <li>
                            <div class="cs-step-num">2</div>
                            Registre a entrega em Minhas Ajudas ao concluir.
                        </li>
                        <li>
                            <div class="cs-step-num">3</div>
                            Avalie a experiencia apos a confirmacao pelo solicitante.
                        </li>
                    </ol>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3 flex-wrap">
                <a asp-page="/Solicitacoes/Detalhes"
                   asp-route-id="@s.Id"
                   class="btn cs-btn-primary px-4">
                    Ver Solicitacao
                </a>
                <a asp-page="/Ajudas/Index"
                   class="btn btn-outline-secondary px-4">
                    Minhas Ajudas
                </a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card cs-card mb-3">
                <div class="card-body text-center py-4">
                    <p class="small text-muted fw-semibold mb-3 text-uppercase">Solicitante</p>
                    <div class="cs-avatar cs-avatar-lg mx-auto mb-2">
                        @(s.Usuario?.NomeCompleto?.Length >= 2
                            ? s.Usuario.NomeCompleto.Substring(0, 2).ToUpper()
                            : "?")
                    </div>
                    <div class="fw-bold fs-6">@(s.Usuario?.NomeCompleto ?? "—")</div>
                    <small class="text-muted">@s.Cidade / @s.Estado</small>
                </div>
            </div>

            <div class="card cs-card mb-3">
                <div class="card-body">
                    <p class="small text-muted fw-semibold mb-2 text-uppercase">
                        Solicitacao vinculada
                    </p>
                    @if (s.Urgencia == "alta")
                    {
                        <span class="badge cs-badge-urgente mb-2">Urgente</span>
                    }
                    <h6 class="fw-bold mb-1">@s.Titulo</h6>
                    <small class="text-muted">@s.Cidade / @s.Estado</small>
                </div>
            </div>

            <div class="card cs-card border-primary">
                <div class="card-body">
                    <p class="small fw-semibold text-primary mb-3 text-uppercase">Acoes rapidas</p>
                    <a asp-page="/Ajudas/ConfirmarEntrega"
                       asp-route-ofertaId="@o.Id"
                       class="btn btn-outline-primary w-100">
                        Registrar entrega
                    </a>
                </div>
            </div>
        </div>
    </div>
}
