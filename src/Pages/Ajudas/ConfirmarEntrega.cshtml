@page
@model ConexaoSolidaria.Pages.Ajudas.ConfirmarEntregaModel
@{
    ViewData["Title"] = "Confirmar Entrega";
}
<a asp-page="/Ajudas/Index" class="text-decoration-none mb-3 d-inline-block">← Voltar</a>
<div class="cs-page-header mb-4">
    <h1 class="cs-page-title">Confirmar Entrega</h1>
    <p class="text-muted">Registre a conclusao da sua entrega de ajuda.</p>
</div>
@if (Model.Oferta == null)
{
    <div class="alert alert-danger">Oferta nao encontrada.</div>
}
else
{
    <form method="post" style="max-width:600px">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
        <div class="card cs-card mb-4">
            <div class="card-body">
                <p class="small text-muted fw-semibold mb-1 text-uppercase">Solicitacao</p>
                <h6 class="fw-bold">@Model.Oferta.Solicitacao?.Titulo</h6>
                <small class="text-muted">
                    @Model.Oferta.Solicitacao?.Cidade / @Model.Oferta.Solicitacao?.Estado
                </small>
            </div>
        </div>
        <div class="mb-4">
            <label asp-for="Input.ObservacoesEntrega" class="form-label fw-semibold">
                Observacoes <span class="text-muted fw-normal">(opcional)</span>
            </label>
            <textarea asp-for="Input.ObservacoesEntrega" class="form-control" rows="3"
                      placeholder="Descreva como foi a entrega..."></textarea>
        </div>
        <input type="hidden" asp-for="Input.OfertaId" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-cs-accent px-4">Confirmar Entrega</button>
            <a asp-page="/Ajudas/Index" class="btn btn-outline-secondary px-4">Cancelar</a>
        </div>
    </form>
}
