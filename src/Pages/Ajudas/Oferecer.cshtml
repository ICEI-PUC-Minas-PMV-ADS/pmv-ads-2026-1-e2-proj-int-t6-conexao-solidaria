@page "/Ajudas/Oferecer"
@model ConexaoSolidaria.Pages.Ajudas.OfereceModel
@{
    ViewData["Title"] = "Como Ajudar";
    var s = Model.Solicitacao;
    var pct = s != null ? (int)(s.PercentualAtendido * 100) : 0;
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-page="/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-page="/Solicitacoes/Index">Solicitacoes</a></li>
        @if (s != null)
        {
            <li class="breadcrumb-item">
                <a asp-page="/Solicitacoes/Detalhes" asp-route-id="@s.Id">Detalhes</a>
            </li>
        }
        <li class="breadcrumb-item active" aria-current="page">Como Ajudar</li>
    </ol>
</nav>

<!-- Título -->
<div class="mb-3">
    <h2 class="fw-bold mb-1">Como voce quer ajudar?</h2>
    <p class="text-muted mb-0">Escolha a modalidade de apoio para esta solicitacao.</p>
</div>

<!-- Stepper -->
<div class="cs-stepper mb-4">
    @{
        string[] stepLabels = { "Viu", "Quer ajudar", "Como ajudar", "Confirmar", "Avaliacao" };
        int activeStep = 2;
    }
    @for (int i = 0; i < stepLabels.Length; i++)
    {
        bool done   = i < activeStep;
        bool active = i == activeStep;
        <div class="cs-step @(active ? "active" : done ? "done" : "")">
            <div class="cs-step-circle">
                @if (done) { <span>&#10003;</span> }
                else       { <span>@(i + 1)</span> }
            </div>
            <span class="cs-step-label">@stepLabels[i]</span>
        </div>
        @if (i < stepLabels.Length - 1)
        {
            <div class="cs-step-line @(done ? "done" : "")"></div>
        }
    }
</div>

@if (s == null)
{
    <div class="alert alert-danger">Solicitacao nao encontrada.</div>
}
else
{
    <div class="row g-4">
        <!-- ═══ COLUNA ESQUERDA ═══════════════════════════════════════════ -->
        <div class="col-lg-7">

            <!-- Card resumo da solicitação -->
            <div class="card cs-card mb-4">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3 mb-2">
                        @if (s.NivelUrgencia == "urgente")
                        {
                            <span class="badge cs-badge-urgente align-self-center">Urgente</span>
                        }
                        <div>
                            <h5 class="fw-bold mb-0">@s.Titulo</h5>
                            <small class="text-muted">@s.Descricao</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <small class="text-muted me-1">Progresso:</small>
                        <div class="progress flex-grow-1" style="height:8px">
                            <div class="progress-bar bg-success" style="width:@pct%"></div>
                        </div>
                        <small class="fw-bold text-success">@pct%</small>
                    </div>
                    <small class="text-muted d-block mt-1">
                        @s.Localizacao &nbsp;|&nbsp; @s.NumeroPessoas pessoa(s)
                    </small>
                </div>
            </div>

            <!-- Formulário de oferta -->
            <form method="post">
                <input type="hidden" asp-for="Input.SolicitacaoId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <!-- Modalidade -->
                <h5 class="fw-semibold mb-3">Escolha a modalidade:</h5>
                <div class="row g-3 mb-4">
                    @{
                        var modalities = new[]
                        {
                            ("doacao",        "Doacao de Itens",
                             "Alimentos, roupas, higiene pessoal e outros itens materiais.",
                             "bi-box-seam"),
                            ("voluntariado",  "Voluntariado Presencial",
                             "Ajude pessoalmente: limpeza, apoio emocional, logistica.",
                             "bi-people"),
                            ("transporte",    "Transporte",
                             "Transporte de pessoas ou itens entre locais de coleta e entrega.",
                             "bi-truck"),
                        };
                    }
                    @foreach (var (val, lbl, desc, ico) in modalities)
                    {
                        bool isFirst = val == "doacao";
                        <div class="col-md-4">
                            <label class="cs-modality-card h-100 @(isFirst ? "selected" : "")"
                                   data-value="@val">
                                <input type="radio"
                                       asp-for="Input.Modalidade"
                                       value="@val"
                                       class="visually-hidden cs-modality-radio"
                                       @(isFirst ? "checked" : "") />
                                <div class="cs-modality-icon mb-2">
                                    <i class="bi @ico fs-4"></i>
                                </div>
                                <div class="fw-semibold mb-1">@lbl</div>
                                <small class="text-muted">@desc</small>
                            </label>
                        </div>
                    }
                </div>

                <!-- Itens (visível somente para doação) -->
                <div id="itensSection" class="mb-4">
                    <h5 class="fw-semibold mb-3">Itens que voce pode entregar:</h5>
                    <div class="row g-2">
                        <div class="col-sm-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       asp-for="Input.ItemAlimentos" id="chkAlimentos" />
                                <label class="form-check-label" for="chkAlimentos">
                                    Alimentos nao-pereciveis
                                </label>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       asp-for="Input.ItemRoupas" id="chkRoupas" />
                                <label class="form-check-label" for="chkRoupas">
                                    Roupas (G / GG)
                                </label>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       asp-for="Input.ItemHigiene" id="chkHigiene" />
                                <label class="form-check-label" for="chkHigiene">
                                    Itens de higiene pessoal
                                </label>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       asp-for="Input.ItemColchoes" id="chkColchoes" />
                                <label class="form-check-label" for="chkColchoes">
                                    Colchoes / Cobertores
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Observações -->
                <div class="mb-4">
                    <label asp-for="Input.Observacoes" class="form-label fw-semibold">
                        Observacoes <span class="text-muted fw-normal">(opcional)</span>
                    </label>
                    <textarea asp-for="Input.Observacoes"
                              class="form-control"
                              rows="3"
                              placeholder="Ex: Posso entregar na quarta-feira a partir das 18h..."></textarea>
                    <span asp-validation-for="Input.Observacoes" class="text-danger small"></span>
                </div>

                <!-- Ações -->
                <div class="d-flex gap-3">
                    <button type="submit" class="btn cs-btn-primary px-4">
                        Confirmar Oferta de Ajuda
                    </button>
                    <a asp-page="/Solicitacoes/Detalhes"
                       asp-route-id="@s.Id"
                       class="btn btn-outline-secondary px-4">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>

        <!-- ═══ COLUNA DIREITA — mapa + solicitante ══════════════════════ -->
        <div class="col-lg-5">

            <!-- Mapa placeholder -->
            <div class="cs-map-placeholder mb-4">
                <div class="cs-map-pin">!</div>
                <span class="cs-map-label">@s.Localizacao</span>
                <div class="cs-map-distance">Localizacao da solicitacao</div>
            </div>

            <!-- Card solicitante -->
            <div class="card cs-card mb-3">
                <div class="card-body">
                    <p class="small text-muted fw-semibold mb-2 text-uppercase">Solicitante</p>
                    <div class="d-flex align-items-center gap-3">
                        <div class="cs-avatar cs-avatar-md">
                            @(s.Usuario?.Nome?.Length >= 2
                                ? s.Usuario.Nome.Substring(0, 2).ToUpper()
                                : "?")
                        </div>
                        <div>
                            <div class="fw-bold">@(s.Usuario?.Nome ?? "—")</div>
                            <small class="text-muted">@s.Localizacao</small>
                            <div class="cs-stars small mt-1">
                                @for (int k = 0; k < 5; k++)
                                {
                                    <span class="text-warning">&#9733;</span>
                                }
                                <span class="text-muted ms-1">4.8</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card outros voluntários -->
            <div class="card cs-card bg-light border-0">
                <div class="card-body">
                    <p class="small text-muted fw-semibold mb-2 text-uppercase">
                        Outros voluntarios confirmados
                    </p>
                    <div class="d-flex align-items-center gap-2">
                        <div class="d-flex">
                            <div class="cs-avatar cs-avatar-sm">JL</div>
                            <div class="cs-avatar cs-avatar-sm" style="margin-left:-8px">AF</div>
                            <div class="cs-avatar cs-avatar-sm" style="margin-left:-8px">CS</div>
                        </div>
                        <small class="text-muted">+2 voluntarios confirmados</small>
                    </div>
                    <small class="text-success fw-semibold mt-1 d-block">Junte-se a eles!</small>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Interatividade dos cards de modalidade
        document.querySelectorAll('.cs-modality-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.cs-modality-card').forEach(c => c.classList.remove('selected'));
                card.classList.add('selected');
                card.querySelector('input[type=radio]').checked = true;

                // Mostrar/ocultar seção de itens
                const isDoacao = card.dataset.value === 'doacao';
                document.getElementById('itensSection').style.display = isDoacao ? '' : 'none';
            });
        });
    </script>
}
