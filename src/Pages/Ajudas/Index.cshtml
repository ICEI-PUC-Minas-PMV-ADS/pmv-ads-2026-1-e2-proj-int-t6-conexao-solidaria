@page
@model ConexaoSolidaria.Pages.Ajudas.IndexModel
@{
    ViewData["Title"] = "Minhas Ajudas";
}

<div class="cs-page-header mb-4">
    <div>
        <h1 class="cs-page-title">Minhas Ajudas</h1>
        <p class="text-muted mb-0">Historico das suas ofertas de ajuda a solicitacoes.</p>
    </div>
</div>

@if (!Model.Ofertas.Any())
{
    <div class="card cs-card text-center py-5">
        <div class="card-body">
            <div style="font-size:3rem">🤝</div>
            <h5 class="fw-bold mt-3">Voce ainda nao ofereceu ajuda</h5>
            <p class="text-muted">Explore as solicitacoes ativas e oferea sua contribuicao.</p>
            <a asp-page="/Solicitacoes/Index" class="btn cs-btn-primary px-4">
                Ver Solicitacoes
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var o in Model.Ofertas)
        {
            var s = o.Solicitacao;
            string badgeClass = o.Status switch
            {
                "confirmada" => "bg-primary",
                "concluida"  => "bg-success",
                "cancelada"  => "bg-secondary",
                _            => "bg-secondary"
            };
            string statusLabel = o.Status switch
            {
                "confirmada" => "Confirmada",
                "concluida"  => "Concluida",
                "cancelada"  => "Cancelada",
                _            => o.Status
            };
            string modalidadeLabel = o.Modalidade switch
            {
                "doacao"       => "Doacao de Itens",
                "voluntariado" => "Voluntariado Presencial",
                "transporte"   => "Transporte",
                _              => o.Modalidade
            };

            <div class="col-12 col-md-6 col-xl-4">
                <div class="card cs-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @badgeClass">@statusLabel</span>
                            <small class="text-muted">@o.CriadaEm.ToLocalTime().ToString("dd/MM/yyyy")</small>
                        </div>
                        <h6 class="fw-bold mb-1">@(s?.Titulo ?? "Solicitacao removida")</h6>
                        <small class="text-muted d-block mb-2">
                            @(s != null ? $"{s.Cidade} / {s.Estado}" : "—")
                        </small>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-light text-dark border">@modalidadeLabel</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(o.Mensagem))
                        {
                            <p class="small text-muted mb-3">"@o.Mensagem"</p>
                        }
                        <div class="d-flex gap-2 flex-wrap">
                            @if (s != null)
                            {
                                <a asp-page="/Solicitacoes/Detalhes"
                                   asp-route-id="@s.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Ver Solicitacao
                                </a>
                            }
                            @if (o.Status == "confirmada")
                            {
                                <a asp-page="/Ajudas/ConfirmarEntrega"
                                   asp-route-ofertaId="@o.Id"
                                   class="btn btn-outline-success btn-sm">
                                    Registrar Entrega
                                </a>
                            }
                            @if (o.Status == "concluida")
                            {
                                <a asp-page="/Avaliacoes/Avaliar"
                                   asp-route-ofertaId="@o.Id"
                                   class="btn btn-outline-warning btn-sm">
                                    Avaliar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
