@page
@model ConexaoSolidaria.Pages.Ajudas.AjudasIndexModel
@{
    ViewData["Title"] = "Minhas Ajudas";
}

<div class="cs-page-header mb-4">
    <div>
        <h1 class="cs-page-title">Minhas Ajudas</h1>
        <p class="cs-page-subtitle">Ofertas de ajuda que você registrou</p>
    </div>
</div>

@if (!Model.Ofertas.Any())
{
    <div class="text-center py-5 bg-white shadow-sm" style="border-radius:15px;">
        <span style="font-size:3rem;">🤝</span>
        <h4 class="mt-3 text-muted">Você ainda não fez nenhuma oferta</h4>
        <p class="text-muted">Acesse as solicitações e ofereça sua ajuda.</p>
        <a asp-page="/Solicitacoes/Index" class="btn btn-cs-primary">Ver Solicitações</a>
    </div>
}
else
{
    foreach (var o in Model.Ofertas)
    {
        <div class="cs-solic-card mb-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h6 class="mb-1 fw-bold">@o.Solicitacao?.Titulo</h6>
                    <small class="text-muted">@o.CriadaEm.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
                <span class="badge bg-@(o.Status == "concluida" ? "success" : o.Status == "cancelada" ? "secondary" : "primary")">
                    @o.Status
                </span>
            </div>
            @if (!string.IsNullOrEmpty(o.Mensagem))
            {
                <p class="mb-0 mt-2 text-muted small">@o.Mensagem</p>
            }
        </div>
    }
}
