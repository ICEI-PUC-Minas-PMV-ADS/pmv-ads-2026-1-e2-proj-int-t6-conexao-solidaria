@page
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="cs-page-header">
    <div>
        <h1 class="cs-page-title">
            Olá, @Model.NomeUsuario
            @if (Model.MediaReputacao > 0)
            {
                <span style="font-size: 18px; color: #F59E0B; margin-left: 8px;" title="Sua média de avaliações">
                    ⭐ @Model.MediaReputacao.ToString("F1")
                </span>
            }
            👋
        </h1>
        <p class="cs-page-subtitle">Veja como você pode ajudar hoje</p>
    </div>
    <div>
        <a asp-page="/Solicitacoes/Nova" class="btn btn-cs-accent">+ Nova Solicitação</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-lg-3">
        <div class="cs-stat-card">
            <div class="label">Pedidos ativos</div>
            <div class="value">@Model.TotalAtivas</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
        <div class="cs-stat-card">
            <div class="label">Urgência alta</div>
            <div class="value" style="color: var(--danger);">@Model.TotalUrgentes</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
        <div class="cs-stat-card">
            <div class="label">Doações a caminho</div>
            <div class="value" style="color: #F28C28;">@Model.DoacoesPendentes</div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
        <div class="cs-stat-card">
            <div class="label">Vidas impactadas</div>
            <div class="value" style="color: #10B981;">@Model.DoacoesEntregues</div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 style="font-size: 18px; font-weight: 700; margin: 0;">Solicitações urgentes próximas</h2>
    <a asp-page="/Solicitacoes/Index" class="text-decoration-none small">Ver todas →</a>
</div>

@if (!Model.SolicitacoesUrgentes.Any())
{
    <div class="alert alert-info">Nenhuma solicitação ativa no momento.</div>
}
else
{
    foreach (var s in Model.SolicitacoesUrgentes)
    {
        <div class="mb-3">
            <div class="cs-solic-card position-relative">
                <a asp-page="/Solicitacoes/Detalhes" asp-route-id="@s.Id" class="text-decoration-none text-dark">
                    <div class="d-flex justify-content-between align-items-start">
                        <h3 class="cs-solic-title">@s.Titulo</h3>
                        <span class="cs-badge @s.Urgencia">@s.Urgencia</span>
                    </div>
                    <div class="cs-solic-meta">
                        📍 @s.Cidade / @s.Estado · 🏷 @s.TipoNecessidade · 🕒 @s.CriadoEm.ToLocalTime().ToString("dd/MM HH:mm")
                    </div>
                </a>
            </div>
        </div>
    }
}