@page
@model ConexaoSolidaria.Pages.Solicitacoes.NovaModel
@{
    ViewData["Title"] = "Nova Solicitação";
}

<a asp-page="/Solicitacoes/Index" class="text-decoration-none mb-3 d-inline-block">← Voltar</a>

<div class="cs-page-header">
    <div>
        <h1 class="cs-page-title">Nova Solicitação</h1>
        <p class="cs-page-subtitle">Descreva sua necessidade para conectar-se a quem pode ajudar</p>
    </div>
</div>

<form method="post" enctype="multipart/form-data" class="cs-form" style="max-width: 720px;">
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <label asp-for="Input.TipoNecessidade"></label>
            <select asp-for="Input.TipoNecessidade" class="form-select">
                <option value="">Selecione...</option>
                <option value="alimentos">Alimentos</option>
                <option value="medicamentos">Medicamentos</option>
                <option value="abrigo">Abrigo</option>
                <option value="vestuario">Vestuário</option>
                <option value="outros">Outros</option>
            </select>
            <span asp-validation-for="Input.TipoNecessidade" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="Input.Urgencia"></label>
            <div class="d-flex gap-3 pt-2">
                <div class="form-check">
                    <input asp-for="Input.Urgencia" type="radio" value="alta" class="form-check-input" id="ua" />
                    <label for="ua" class="form-check-label">🔴 Alta</label>
                </div>
                <div class="form-check">
                    <input asp-for="Input.Urgencia" type="radio" value="media" class="form-check-input" id="um" checked />
                    <label for="um" class="form-check-label">🟡 Média</label>
                </div>
                <div class="form-check">
                    <input asp-for="Input.Urgencia" type="radio" value="baixa" class="form-check-input" id="ub" />
                    <label for="ub" class="form-check-label">🟢 Baixa</label>
                </div>
            </div>
        </div>

        <div class="col-12">
            <label asp-for="Input.Titulo"></label>
            <input asp-for="Input.Titulo" class="form-control"
                   placeholder="Ex.: Cesta básica para família de 4 pessoas" />
            <span asp-validation-for="Input.Titulo" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label asp-for="Input.Descricao"></label>
            <textarea asp-for="Input.Descricao" class="form-control" rows="5"
                      placeholder="Descreva detalhadamente sua necessidade, quantidades, prazos..."></textarea>
            <span asp-validation-for="Input.Descricao" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-8">
            <label asp-for="Input.Cidade"></label>
            <input asp-for="Input.Cidade" class="form-control" placeholder="Sua cidade" />
            <span asp-validation-for="Input.Cidade" class="text-danger small"></span>
        </div>

        <div class="col-12 col-md-4">
            <label asp-for="Input.Estado"></label>
            <input asp-for="Input.Estado" class="form-control text-uppercase"
                   placeholder="UF" maxlength="2" />
            <span asp-validation-for="Input.Estado" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label for="Anexo">Anexo (opcional)</label>
            <input asp-for="Anexo" type="file" accept="image/*" class="form-control" />
            <small class="text-muted">Foto da situação ou receita médica (até 5 MB)</small>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-cs-primary">Publicar Solicitação</button>
        <a asp-page="/Solicitacoes/Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
