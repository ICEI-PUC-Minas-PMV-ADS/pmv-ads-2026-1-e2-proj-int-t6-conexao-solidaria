@{
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
    var userName = User.Identity?.IsAuthenticated == true
        ? (User.Identity.Name ?? "Usuário")
        : "Visitante";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Conexão Solidária</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <!-- HEADER FIXO -->
    <header class="cs-header">
        <div class="cs-header-inner">
            <div class="cs-brand">
                <span class="cs-brand-logo">CS</span>
                <span class="cs-brand-name">CONEXÃO <span class="cs-accent">SOLIDÁRIA</span></span>
            </div>
            <div class="cs-user-pill">
                <span class="cs-user-avatar">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "?")</span>
                <span class="cs-user-name d-none d-md-inline">@userName</span>
                <form method="post" asp-page="/Logout" class="d-inline">
                    <button type="submit" class="cs-logout" title="Sair">↪</button>
                </form>
            </div>
        </div>
    </header>

    <div class="cs-shell">
        <!-- SIDEBAR (220px, oculta no mobile) -->
        <nav class="cs-sidebar">
            <ul class="cs-nav">
                <li class="@(currentPath == "/" || currentPath == "/dashboard" ? "active" : "")">
                    <a asp-page="/Dashboard">🏠 <span>Início</span></a>
                </li>
                <li class="@(currentPath.StartsWith("/solicitacoes") ? "active" : "")">
                    <a asp-page="/Solicitacoes/Index">📋 <span>Solicitações</span></a>
                </li>
                <li>
                    <a href="#">🎁 <span>Doações</span></a>
                </li>
                <li>
                    <a href="#">💬 <span>Chat</span></a>
                </li>
                <li class="@(currentPath.StartsWith("/perfil") ? "active" : "")">
                    <a asp-page="/Perfil/Index">👤 <span>Perfil</span></a>
                </li>
            </ul>
            <div class="cs-sidebar-footer">
                <a href="#">⚙ <span>Configurações</span></a>
            </div>
        </nav>

        <!-- CONTEÚDO PRINCIPAL -->
        <main class="cs-content">
            @RenderBody()
        </main>
    </div>

    <!-- BOTTOM NAV (mobile, < 768px) -->
    <nav class="cs-bottom-nav">
        <a asp-page="/Dashboard" class="@(currentPath == "/" || currentPath == "/dashboard" ? "active" : "")">
            <span>🏠</span><small>Início</small>
        </a>
        <a asp-page="/Solicitacoes/Index" class="@(currentPath.StartsWith("/solicitacoes") ? "active" : "")">
            <span>📋</span><small>Pedidos</small>
        </a>
        <a href="#"><span>🎁</span><small>Doações</small></a>
        <a href="#"><span>💬</span><small>Chat</small></a>
        <a asp-page="/Perfil/Index" class="@(currentPath.StartsWith("/perfil") ? "active" : "")">
            <span>👤</span><small>Perfil</small>
        </a>
    </nav>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
