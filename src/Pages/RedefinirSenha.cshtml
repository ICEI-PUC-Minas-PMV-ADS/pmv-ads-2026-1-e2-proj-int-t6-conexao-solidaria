@page
@model ConexaoSolidaria.Pages.RedefinirSenhaModel
@{
    ViewData["Title"] = "Criar Nova Senha";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <span style="font-size: 3rem;">🔑</span>
                        <h3 class="fw-bold mt-2">Nova Senha</h3>
                        <p class="text-muted">Crie uma nova senha segura para a sua conta.</p>
                    </div>

                    <form method="post">
                        <input asp-for="Input.Token" type="hidden" />
                        <input asp-for="Input.Email" type="hidden" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nova Senha</label>
                            <input asp-for="Input.NovaSenha" class="form-control bg-light border-0" placeholder="********" />
                            <span asp-validation-for="Input.NovaSenha" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Confirmar Nova Senha</label>
                            <input asp-for="Input.ConfirmarSenha" class="form-control bg-light border-0" placeholder="********" />
                            <span asp-validation-for="Input.ConfirmarSenha" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" style="border-radius: 10px;">Salvar Senha</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>