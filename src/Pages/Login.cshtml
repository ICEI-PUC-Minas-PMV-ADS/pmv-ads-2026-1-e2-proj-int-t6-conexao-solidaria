@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutPublic";
}

<div class="cs-public-card">
    <div class="cs-public-brand">
        <div class="cs-public-brand-logo">CS</div>
        <div class="cs-public-brand-title">Bem-vindo de volta</div>
        <div class="cs-public-brand-subtitle">Acesse sua conta para continuar</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" class="cs-form">
        <div class="mb-3">
            <label asp-for="Input.Email">E-mail</label>
            <input asp-for="Input.Email" type="email" class="form-control"
                   placeholder="seu@email.com" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Senha">Senha</label>
            <input asp-for="Input.Senha" type="password" class="form-control"
                   placeholder="Sua senha" autocomplete="current-password" />
            <span asp-validation-for="Input.Senha" class="text-danger small"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="Input.LembrarMe" class="form-check-input" />
            <label asp-for="Input.LembrarMe" class="form-check-label">Lembrar de mim</label>
        </div>

        <button type="submit" class="btn btn-cs-primary w-100 mb-3">Entrar</button>
    </form>

    <div class="text-center">
        <a href="#" class="text-muted small">Esqueci minha senha</a>
        <hr />
        <small class="text-muted">
            Ainda não tem conta? <a asp-page="/CriarConta">Criar conta</a>
        </small>
    </div>
</div>
