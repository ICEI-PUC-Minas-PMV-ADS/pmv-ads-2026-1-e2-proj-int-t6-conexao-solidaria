@model IEnumerable<ConexaoSolidaria.Models.ChatApoio>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ConexaoSolidaria.Models.Usuario> UserManager
@{
    ViewData["Title"] = "Minhas Conversas";
    Layout = "~/Pages/Shared/_Layout.cshtml";
    var currentUserId = UserManager.GetUserId(User);
}

<div class="cs-page-header mb-4">
    <div>
        <h1 class="cs-page-title">Mensagens</h1>
        <p class="cs-page-subtitle">Acompanhe suas conversas sobre doações e pedidos</p>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-8 mx-auto">
        @if (!Model.Any())
        {
            <div class="text-center py-5 bg-white shadow-sm" style="border-radius: 15px;">
                <span style="font-size: 3rem;">💬</span>
                <h4 class="mt-3 text-muted">Nenhuma conversa iniciada</h4>
                <p class="text-muted">Suas conversas aparecerão aqui quando você oferecer ou receber uma doação.</p>
            </div>
        }
        else
        {
            foreach (var chat in Model)
            {
                // quem é a "outra pessoa" na conversa
                var ehDoador = chat.Doacao?.DoadorId == currentUserId;
                var outraPessoa = ehDoador
                    ? chat.Doacao?.Solicitacao?.Usuario?.NomeCompleto
                    : chat.Doacao?.Doador?.NomeCompleto;
                
                var ultimaMsg = chat.Mensagens.OrderByDescending(m => m.EnviadaEm).FirstOrDefault();

                <a href="/Chat?doacaoId=@chat.DoacaoId" class="text-decoration-none text-dark">
                    <div class="card mb-3 shadow-sm border-0 cs-solic-card" style="transition: transform 0.2s;">
                        <div class="card-body d-flex align-items-center">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                 style="width: 50px; height: 50px; font-size: 20px; font-weight: bold;">
                                @outraPessoa?[0]
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0 fw-bold">@outraPessoa</h6>
                                    <small class="text-muted">@ultimaMsg?.EnviadaEm.ToString("dd/MM HH:mm")</small>
                                </div>
                                <div class="text-truncate text-muted small" style="max-width: 300px;">
                                    <strong>@chat.Doacao?.Solicitacao?.Titulo:</strong> @(ultimaMsg?.Conteudo ?? "Nenhuma mensagem ainda...")
                                </div>
                            </div>
                            <div class="ms-2">
                                <span class="text-primary">→</span>
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>