@{
    ViewData["Title"] = "Avaliar Doador";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm" style="border-radius: 15px; border: none;">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <span style="font-size: 3rem;">🌟</span>
                    </div>
                    <h2 class="fw-bold mb-3">Avaliar Ajuda</h2>
                    <p class="text-muted">Como foi sua experiência com a doação de <strong>@ViewBag.DoadorNome</strong>?</p>
                    
                    <form asp-action="Avaliar" method="post" class="mt-4">
                        <input type="hidden" name="doacaoId" value="@ViewBag.DoacaoId" />
                        <input type="hidden" name="avaliadoId" value="@ViewBag.DoadorId" />

                        <div class="star-rating mb-4">
                            <input type="radio" id="star5" name="nota" value="5" required /><label for="star5">★</label>
                            <input type="radio" id="star4" name="nota" value="4" /><label for="star4">★</label>
                            <input type="radio" id="star3" name="nota" value="3" /><label for="star3">★</label>
                            <input type="radio" id="star2" name="nota" value="2" /><label for="star2">★</label>
                            <input type="radio" id="star1" name="nota" value="1" /><label for="star1">★</label>
                        </div>

                        <div class="form-group mb-4 text-start">
                            <label class="fw-bold mb-2 text-dark">Conte um pouco mais (opcional):</label>
                            <textarea name="comentario" class="form-control" rows="3" placeholder="Ex: O doador foi muito atencioso e os itens estavam ótimos!"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-lg text-white" style="background-color: #F28C28; border-radius: 10px; font-weight: 600;">
                                Enviar Avaliação
                            </button>
                            <a href="/Doacoes" class="btn btn-link text-muted text-decoration-none">Agora não</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilização das Estrelas (Lógica Inversa para o CSS funcionar) */
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        font-size: 3rem;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            color: #E2E8F0;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            padding: 0 5px;
        }

            /* Quando passa o mouse ou seleciona */
            .star-rating input:checked ~ label,
            .star-rating label:hover,
            .star-rating label:hover ~ label {
                color: #F59E0B; /* Cor dourada vibrante */
                transform: scale(1.1);
            }
</style>