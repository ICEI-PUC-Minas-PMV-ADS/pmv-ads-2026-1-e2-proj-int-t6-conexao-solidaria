@model ConexaoSolidaria.Models.Doacao

@{
    ViewData["Title"] = "Oferecer Ajuda";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            <div class="card shadow-sm" style="border-radius: 12px; border: 1px solid #E2E8F0;">
                <div class="card-header text-white" style="background-color: #1E73BE; border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h4 class="mb-0 py-2">💖 Como Ajudar (Nova Doação)</h4>
                </div>
                
                <div class="card-body p-4" style="background-color: #F8FAFD;">
                    <p class="text-muted mb-4">Preencha os dados abaixo para registrar sua oferta de ajuda. Ela será vinculada diretamente à solicitação de quem precisa.</p>
                    
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="DoadorId" class="control-label fw-bold text-dark">Quem está doando?</label>
                            <select asp-for="DoadorId" class="form-select" asp-items="ViewBag.ListaDoadores">
                                <option value="">-- Selecione o Doador --</option>
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="SolicitacaoId" class="control-label fw-bold text-dark">Qual solicitação você quer atender?</label>
                            <select asp-for="SolicitacaoId" class="form-select" asp-items="ViewBag.ListaSolicitacoes">
                                <option value="">-- Selecione a Solicitação --</option>
                            </select>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ItensDoados" class="control-label fw-bold text-dark">O que você está doando?</label>
                            <textarea asp-for="ItensDoados" class="form-control" rows="4" placeholder="Ex: 2 pacotes de arroz, 1 pacote de feijão, agasalhos de frio..."></textarea>
                            <span asp-validation-for="ItensDoados" class="text-danger"></span>
                        </div>

                        <hr class="mb-4" />

                        <div class="form-group d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="text-decoration-none" style="color: #1E73BE;">← Voltar para Lista</a>
                            
                            <button type="submit" class="btn fw-bold text-white px-4 py-2" style="background-color: #F28C28; border-radius: 8px;">
                                Confirmar minha oferta de ajuda
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
