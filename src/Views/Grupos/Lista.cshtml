@model IEnumerable<ConexaoSolidaria.Models.GrupoApoio>
@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Grupos de Apoio";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}
<div class="cs-page-header mb-4">
    <div>
        <h1 class="cs-page-title">Grupos de Apoio</h1>
        <p class="cs-page-subtitle">Encontre e participe de redes de solidariedade e apoio mútuo</p>
    </div>
  <div>
<a asp-controller="Grupos" asp-action="Criar" class="btn btn-cs-accent">Criar Grupo</a>
    </div>
</div>
<div class="card shadow-sm" style="border-radius: 12px; border: 1px solid 
#E2E8F0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0" style="vertical-align: middle;">
<thead style="background-color: 
#F8FAFD; color: 
#475569; font-size: 14px;">
                <tr>
                    <th class="px-4 py-3 border-bottom-0">Todos</th>
                    <th class="px-4 py-3 border-bottom-0">Doação</th>
                    <th class="px-4 py-3 border-bottom-0">Voluntariado</th>
                    <th class="px-4 py-3 border-bottom-0">Ambos</th>
                    <th class="px-4 py-3 border-bottom-0">Meus grupos</th>
                </tr>
            </thead>
</table>
  <!-- <div class="col-12 col-md-6">
             <div class="d-flex gap-3 pt-2">
                <div class="form-check">
                    <input type="radio" class="form-check-input" id="ua" checked/>
                    <label for="ua" class="form-label fw-bold">Todos</label>
                </div>
                <div class="form-check">
                    <input type="radio" value="voluntariado" class="form-check-input" id="um" />
                    <label for="um" class="form-label fw-bold">Doação</label>
                </div>
                <div class="form-check">
                    <input type="radio" value="ambos" class="form-check-input" id="ub" />
                    <label for="ub" class="form-check-label fw-bold">Ambos</label>
                </div>
            </div>
        </div>
 -->
<div class="row">
    <div class="col-12 col-lg-8 mx-auto">
        @if  (Model == null || !Model.Any())
        {
            <div class="text-center py-5 bg-white shadow-sm" style="border-radius: 15px;">
                <span style="font-size: 3rem;">👥</span>
                <h4 class="mt-3 text-muted">Nenhum grupo encontrado</h4>
                <p class="text-muted">Ainda não existem grupos de apoio cadastrados no sistema.</p>
            </div>
        }
        else
        {
            foreach (var grupo in Model)
            {
                <a href="/Grupos/Detalhes/@grupo.Id" class="text-decoration-none text-dark">
                <div class="card mb-3 shadow-sm border-0 cs-solic-card"
     style="transition: transform 0.2s; border-radius: 12px; overflow: hidden;">

     <!-- parte superior --> 
    <div class="d-flex align-items-center gap-3"
         style="background-color: 
#1A6FBF; padding: 16px 20px;">
  <!-- bolinha verde canto superior direito -->
        <span class="position-absolute top-0 end-0 m-2"
              style="width:9px;height:9px;border-radius:50%;
                     background:#2DBE60;display:inline-block;"></span>
        <div class="rounded-circle bg-white d-flex align-items-center justify-content-center fw-bold"
             style="width: 48px; height: 48px; font-size: 20px; color: 
#1A6FBF; flex-shrink: 0;">
            @(!string.IsNullOrEmpty(grupo.Nome) ? grupo.Nome.Substring(0, 1).ToUpper() : "G")
        </div>
        <div>
            <h6 class="mb-0 fw-bold text-white">@grupo.Nome</h6>
        </div>
    </div>
       <!-- parte inferior -->
    <div class="d-flex justify-content-between align-items-center bg-white"
         style="padding: 14px 20px;">
        <p class="mb-0 text-muted small text-truncate" style="max-width: 420px;">
            @grupo.Descricao
</p>
        <span class="fw-bold" style="font-size:13px; color:var(--primary);">Número de membros:</span>
        <span class="text-primary fw-bold ms-3">→</span>
    </div>
</div>
                </a>
            }
        }
    </div>
</div>
