    <div>
        <h1 class="cs-page-title">Grupos de Apoio</h1>
        <p class="cs-page-subtitle">Encontre e participe de redes de solidariedade e apoio mútuo</p>
    </div>
  <div>
<a asp-controller="Grupos" asp-action="Criar" class="btn btn-cs-accent">Criar Grupo</a>
    </div>
</div>
<div class="card shadow-sm" style="border-radius: 12px; border: 1px solid 
#E2E8F0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0" style="vertical-align: middle;">
<thead style="background-color: 
#F8FAFD; color: 
#475569; font-size: 14px;">
                <tr>
                    <th class="px-4 py-3 border-bottom-0">Todos</th>
                    <th class="px-4 py-3 border-bottom-0">Doação</th>
                    <th class="px-4 py-3 border-bottom-0">Voluntariado</th>
                    <th class="px-4 py-3 border-bottom-0">Ambos</th>
                    <th class="px-4 py-3 border-bottom-0">Meus grupos</th>
                </tr>
            </thead>
</table>
