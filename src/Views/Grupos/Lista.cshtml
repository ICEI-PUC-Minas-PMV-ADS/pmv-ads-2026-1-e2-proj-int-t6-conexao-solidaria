@model IEnumerable<ConexaoSolidaria.Models.GrupoApoio>
@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Grupos de Apoio";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="cs-page-header mb-4">
    <div>
        <h1 class="cs-page-title">Grupos de Apoio</h1>
        <p class="cs-page-subtitle">Encontre e participe de redes de solidariedade e apoio mútuo</p>
    </div>
</div>
  <div>
<a asp-controller="Grupos" asp-action="Criar" class="btn btn-cs-accent">Criar Grupo</a>
<div class="card shadow-sm" style="border-radius: 12px; border: 1px solid #E2E8F0; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-hover mb-0" style="vertical-align: middle;">
<thead style="background-color: #F8FAFD; color: #475569; font-size: 14px;">
                <tr>
                    <th class="px-4 py-3 border-bottom-0">grupos</th>
                    <th class="px-4 py-3 border-bottom-0">ultimo</th>
                    <th class="px-4 py-3 border-bottom-0">sugestão</th>
                    <th class="px-4 py-3 border-bottom-0 text-center">opções</th>
                </tr>
            </thead>
    </div>
</div> 
<div class="row">
    <div class="col-12 col-lg-8 mx-auto">
        @if  (Model == null || !Model.Any())
        {
            <div class="text-center py-5 bg-white shadow-sm" style="border-radius: 15px;">
                <span style="font-size: 3rem;">👥</span>
                <h4 class="mt-3 text-muted">Nenhum grupo encontrado</h4>
                <p class="text-muted">Ainda não existem grupos de apoio cadastrados no sistema.</p>
            </div>
        }
        else
        {
            foreach (var grupo in Model)
            {
                <a href="/Grupos/Detalhes/@grupo.Id" class="text-decoration-none text-dark">
                    <div class="card mb-3 shadow-sm border-0 cs-solic-card" style="transition: transform 0.2s;">
                        <div class="card-body d-flex align-items-center">
                            
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                 style="width: 50px; height: 50px; font-size: 20px; font-weight: bold;">
                                @(!string.IsNullOrEmpty(grupo.Nome) ? grupo.Nome.Substring(0, 1).ToUpper() : "G")
                            </div>
                            
                            <div class="ms-3 flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0 fw-bold">@grupo.Nome</h6>
                                </div>
                                <div class="text-truncate text-muted small" style="max-width: 400px;">
                                    @grupo.Descricao
                                </div>
                            </div>
                            
                            <div class="ms-2">
                                <span class="text-primary">→</span>
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>
