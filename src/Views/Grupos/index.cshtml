@{
    ViewData["Title"] = "Grupos";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Grupos</h2>
            <p class="text-muted mb-0">
                Encontre grupos para participar ou crie o seu próprio.
            </p>
        </div>

        <a asp-controller="Grupos"
           asp-action="Criar"
           class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Criar Grupo
        </a>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">

                    <h5 class="card-title">
                        Enchente Petrópolis 2026
                    </h5>

                    <p class="card-text text-muted">
                        Apoio às famílias atingidas pelas enchentes.
                    </p>

                    <span class="badge bg-primary">
                        Misto
                    </span>

                    <hr />

                    <p class="mb-2">
                        <strong>Cidade:</strong> Petrópolis/RJ
                    </p>

                    <p class="mb-0">
                        <strong>Membros:</strong> 24
                    </p>

                </div>

                <div class="card-footer bg-white">
                    <a href="#" class="btn btn-outline-primary w-100">
                        Ver Grupo
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">

                    <h5 class="card-title">
                        Campanha do Agasalho
                    </h5>

                    <p class="card-text text-muted">
                        Arrecadação de roupas para o inverno.
                    </p>

                    <span class="badge bg-success">
                        Doação
                    </span>

                    <hr />

                    <p class="mb-2">
                        <strong>Cidade:</strong> Belo Horizonte/MG
                    </p>

                    <p class="mb-0">
                        <strong>Membros:</strong> 15
                    </p>

                </div>

                <div class="card-footer bg-white">
                    <a href="#" class="btn btn-outline-primary w-100">
                        Ver Grupo
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">

                    <h5 class="card-title">
                        Voluntários da Saúde
                    </h5>

                    <p class="card-text text-muted">
                        Ações de apoio em comunidades locais.
                    </p>

                    <span class="badge bg-warning text-dark">
                        Voluntariado
                    </span>

                    <hr />

                    <p class="mb-2">
                        <strong>Cidade:</strong> Contagem/MG
                    </p>

                    <p class="mb-0">
                        <strong>Membros:</strong> 32
                    </p>

                </div>

                <div class="card-footer bg-white">
                    <a href="#" class="btn btn-outline-primary w-100">
                        Ver Grupo
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
