@model ConexaoSolidaria.Models.Grupo
@{
    ViewData["Title"] = "Novo Grupo";
}

<a asp-action="Lista" class="text-decoration-none mb-3 d-inline-block">← Voltar</a>

<div class="cs-page-header mb-4">
    <div>
        <h1 class="cs-page-title">Novo Grupo</h1>
        <p class="cs-page-subtitle">Conecte-se com pessoas</p>
    </div>
</div>
<!-- enctype="multipart/form-data" -->
<form asp-controller="Grupos" asp-action="Criar" method="post" style="max-width:720px;">
<div class="d-flex gap-4 align-items-start">

<div class="flex-shrink-0">
    <label class="form-label fw-bold text-uppercase small">Foto do Grupo</label>

    <div id="fotoBox"
         class="cs-upload-box d-flex flex-column align-items-center justify-content-center"
         style="width:120px; height:140px; border-radius:10px; cursor:pointer; overflow:hidden; position:relative;"
         onclick="document.getElementById('fotoInput').click()">

        <!-- Placeholder padrão -->
        <div id="fotoPlaceholder" class="text-center" style="color: var(--primary);">
            <div style="font-size:1.8rem; font-weight:700;">[ + ]</div>
            <small>Adicionar foto</small>
        </div>

        <!-- Prévia da imagem (oculta até selecionar) -->
        <img id="fotoPreview"
             src="#"
             alt="Prévia"
             style="display:none; width:100%; height:100%; object-fit:cover; border-radius:10px;" />
    </div>

    <input type="file" id="fotoInput" name="Foto" accept="image/*" class="d-none"
           onchange="mostrarPrevia(event)" />
</div>

<script>
    function mostrarPrevia(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function (e) {
            document.getElementById('fotoPlaceholder').style.display = 'none';
            const preview = document.getElementById('fotoPreview');
            preview.src = e.target.result;
            preview.style.display = 'block';
        };
        reader.readAsDataURL(file);
    }
</script>
    <div class="flex-grow-1">
        <div class="col-12">
            <label asp-for="Nome" class="form-label fw-semibold">NOME DO GRUPO *</label>
            <input asp-for="Nome" class="form-control" placeholder="Nome do grupo" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Descricao" class="form-label fw-semibold">DESCRIÇÃO CURTA *</label>
            <textarea asp-for="Descricao" class="form-control" rows="1"
                      placeholder="Descreva o objetivo do grupo..."></textarea>
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>
   <div class="col-12 col-md-6">
            <label asp-for="TipoAtiv">TIPO DE ATIVIDADE *</label>
            <div class="d-flex gap-3 pt-2">
                <div class="form-check">
                    <input asp-for="TipoAtiv" type="radio" value="doacao" class="form-check-input" id="ua" />
                    <label for="ua" class="form-check-label">🔵 DOAÇÃO</label>
                </div>
                <div class="form-check">
                    <input asp-for="TipoAtiv" type="radio" value="voluntariado" class="form-check-input" id="um" checked />
                    <label for="um" class="form-check-label">🟡 VOLUNTÁRIADO</label>
                </div>
                <div class="form-check">
                    <input asp-for="TipoAtiv" type="radio" value="ambos" class="form-check-input" id="ub" />
                    <label for="ub" class="form-check-label">🟢 Ambos</label>
                </div>
            </div>
        </div>
 <div class="col-12">
            <label asp-for="DescricaoDetalhada" class="form-label fw-semibold">DESCRIÇÃO DETALHADA</label>
            <textarea asp-for="DescricaoDetalhada" class="form-control" rows="5"
                      placeholder="Descreva mais o grupo..."></textarea>
            <span asp-validation-for="DescricaoDetalhada" class="text-danger small"></span>
        </div>
 <div class="row g-3">
 <div class="col-12 col-md-8">
            <label asp-for="Cidade" class="form-label fw-semibold">CIDADE *</label>
            <input asp-for="Cidade" class="form-control" placeholder="Informe sua cidade" />
            <span asp-validation-for="Cidade" class="text-danger small"></span>
        </div>
 <div class="col-12 col-md-4">
                <label class="form-label fw-bold text-uppercase small">UF *</label>
                <select asp-for="Estado" class="form-select">
                    <option value="">UF</option>
                    <option>AC</option><option>AL</option><option>AM</option>
                    <option>BA</option><option>CE</option><option>DF</option>
                    <option>ES</option><option>GO</option><option>MA</option>
                    <option>MG</option><option>MS</option><option>MT</option>
                    <option>PA</option><option>PB</option><option>PE</option>
                    <option>PI</option><option>PR</option><option>RJ</option>
                    <option>RN</option><option>RO</option><option>RR</option>
                    <option>RS</option><option>SC</option><option>SE</option>
                    <option>SP</option><option>TO</option>
                </select>
 <span asp-validation-for="Estado" class="text-danger small"></span>
            </div>
 </div>
    </div></div>
  <div class="mt-4">
            <label class="form-label fw-bold text-uppercase small">Privacidade</label>
            <div class="form-check">
                <input asp-for="Publico" class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Grupo publico - qualquer usuario pode entrar</label>
            </div>
        </div>
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-cs-accent">Criar Grupo</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
