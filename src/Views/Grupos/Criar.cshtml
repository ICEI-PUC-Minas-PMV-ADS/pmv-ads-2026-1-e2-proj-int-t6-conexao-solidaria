@{
    ViewData["Title"] = "Criar Grupo";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <a asp-action="Index" class="text-decoration-none">
        ← Voltar para Grupos
    </a>

    <h1 class="mt-3">Criar Novo Grupo</h1>

    <p class="text-muted">
        Reúna pessoas em torno de uma causa comum.
    </p>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body">

            <form method="post"
      enctype="multipart/form-data">

                <div class="row">

                    <div class="col-md-2">
                        <label class="form-label fw-bold">
                            FOTO DO GRUPO
                        </label>

                      <div class="border border-primary text-center p-4">

    <input type="file"
           id="FotoGrupo"
           name="FotoGrupo"
           accept="image/*"
           class="form-control" />

    <small>Adicionar foto</small>

</div>
                    </div>

                    <div class="col-md-10">

                        <label class="form-label">
                            Nome do Grupo *
                        </label>

                        <input class="form-control"
                               placeholder="Ex: Enchente Petrópolis 2026">

                        <label class="form-label mt-3">
                            Descrição Curta *
                        </label>

                        <input class="form-control"
                               placeholder="Apoio às famílias atingidas">
                    </div>

                </div>

                <div class="mt-4">
                    <label class="fw-bold">
                        Tipo de Atividade *
                    </label>
                </div>

                <div class="row mt-2">

                    <div class="col-md-4">
                        <div class="card p-3">
                            <input type="radio" name="tipo">
                            Doação
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card p-3">
                            <input type="radio" name="tipo">
                            Voluntariado
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card p-3 border-primary">
                            <input type="radio" name="tipo">
                            Misto
                        </div>
                    </div>

                </div>

                <div class="mt-3">
                    <label>Descrição Detalhada</label>

                    <textarea class="form-control"
                              rows="4"></textarea>
                </div>

                <div class="row mt-3">

                    <div class="col-md-10">
                        <label>Cidade *</label>

                        <input class="form-control">
                    </div>

                    <div class="col-md-2">
                        <label>UF *</label>

                        <select class="form-select">
                            <option>MG</option>
                        </select>
                    </div>

                </div>

                <div class="mt-3">
                    <input type="checkbox">
                    Grupo público
                </div>

                <div class="text-end mt-4">

                    <a asp-action="Index"
                       class="btn btn-light">
                        Cancelar
                    </a>

                    <button class="btn btn-warning text-white">
                        Criar Grupo
href="/Grupos/Criar
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>
